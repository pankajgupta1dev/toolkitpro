    <script>
        // Get current domain and update all domain references
        function updateDomainReferences() {
            const currentDomain = window.location.hostname.replace('www.', '');
            const domainElements = [
                'header-logo', 'disclaimer-domain', 'disclaimer-domain2', 'disclaimer-domain3', 
                'footer-logo', 'copyright-domain'
            ];
            
            domainElements.forEach(id => {
                const element = document.getElementById(id);
                if (element) {
                    element.textContent = currentDomain || 'LearnForAll';
                }
            });

            // Update disclaimer email with current domain
            const disclaimerEmail = document.getElementById('disclaimer-email');
            if (disclaimerEmail) {
                disclaimerEmail.textContent = `contact@${currentDomain || 'example.com'}`;
                disclaimerEmail.href = `mailto:contact@${currentDomain || 'example.com'}`;
            }
        }

        // Set current date
        function setCurrentDate() {
            const options = { year: 'numeric', month: 'long', day: 'numeric' };
            const today = new Date();
            document.getElementById('current-date').textContent = today.toLocaleDateString('en-US', options);
        }

        // Toggle dropdown menu
        function toggleDropdown() {
            const dropdown = document.querySelector('.dropdown');
            dropdown.classList.toggle('active');
        }

        // Toggle mobile menu
        function toggleMobileMenu() {
            const mobileMenu = document.querySelector('.mobile-menu');
            mobileMenu.classList.toggle('active');
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
            const dropdown = document.querySelector('.dropdown');
            const toolsButton = event.target.closest('button');
            
            if (!toolsButton || !toolsButton.textContent.includes('Tools')) {
                dropdown.classList.remove('active');
            }
        });

        // Initialize domain references and current date on page load
        document.addEventListener('DOMContentLoaded', function() {
            updateDomainReferences();
            setCurrentDate();
        });
